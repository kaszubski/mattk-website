---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
---

<BaseLayout t={t}>
  <Nav t={t} activePage="home" />

  <main id="main-content">

    <!-- ── Intro ──────────────────────────────────────────── -->
    <section class="intro" aria-label="Introduction">
      <div class="container">
        <div class="intro__inner">
          <h1 class="intro__name">Matt Kaszubski</h1>
          <p class="intro__body">{t.home.intro}</p>
        </div>
      </div>
    </section>

    <!-- ── Writing ───────────────────────────────────────── -->
    <section id="writing" aria-labelledby="writing-heading">
      <div class="container">
        <h2 id="writing-heading" class="section-label">{t.home.writing.title}</h2>

        <ol class="posts" role="list">
          {
            t.home.writing.posts.map((post) => (
              <li class="post reveal">
                <a
                  class="post__link"
                  href={post.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  <span class="post__title">{post.title}</span>
                  <span class="post__date">{post.date}</span>
                </a>
                <p class="post__desc">{post.description}</p>
              </li>
            ))
          }
        </ol>

        <a
          class="all-posts"
          href={t.home.writing.allPostsUrl}
          rel="noopener noreferrer"
          target="_blank"
        >
          {t.home.writing.allPosts} &rarr;
        </a>
      </div>
    </section>

  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  /* ── Intro ────────────────────────────────────────────── */
  .intro {
    padding-block: var(--space-2xl) var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .intro__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .intro__name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.035em;
    line-height: 1;
    color: var(--color-text);
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 48;
  }

  .intro__body {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 56ch;
  }

  @media (min-width: 768px) {
    .intro__inner {
      grid-template-columns: 14rem 1fr;
      gap: var(--space-2xl);
      align-items: start;
    }
  }

  /* ── Writing ─────────────────────────────────────────── */
  .section-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    padding-block: var(--space-xl) var(--space-lg);
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .post {
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-lg);
  }

  .post__link {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    text-decoration: none;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .post__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.02em;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 24;
    transition: color var(--transition);
    line-height: 1.2;
  }

  .post__link:hover .post__title {
    color: var(--color-accent);
  }

  .post__date {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
    letter-spacing: 0.06em;
    flex-shrink: 0;
  }

  .post__desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    max-width: 58ch;
  }

  .all-posts {
    display: inline-block;
    margin-top: var(--space-lg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color var(--transition);
    padding-bottom: var(--space-2xl);
  }

  .all-posts:hover {
    color: var(--color-accent);
  }

  /* ── Hero load animation ──────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes hero-in {
      from { opacity: 0; translate: 0 0.6rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .intro__name {
      animation: hero-in 0.5s ease-out both;
    }

    .intro__body {
      animation: hero-in 0.5s ease-out 0.1s both;
    }
  }
</style>
