---
import type { Translations } from "@/i18n";

interface Props {
  t: Translations;
  activePage?: "home" | "about";
}

const { t, activePage = "home" } = Astro.props;
---

<header class="site-header">
  <nav class="container container--wide nav" aria-label="Primary navigation">
    <a class="nav__logo" href="/" aria-label={`${t.siteTitle} — home`}>
      <span aria-hidden="true">MK</span>
    </a>

    <ul class="nav__list" role="list">
      <li>
        <a
          href="/#writing"
          aria-current={activePage === "home" ? "page" : undefined}
        >
          {t.nav.writing}
        </a>
      </li>
      <li>
        <a
          href="/about/"
          aria-current={activePage === "about" ? "page" : undefined}
        >
          {t.nav.about}
        </a>
      </li>
      <li>
        <a
          href="https://www.meetup.com/engineering-leadership-warsaw/"
          rel="noopener noreferrer"
          target="_blank"
        >
          {t.nav.elw}
          <span class="sr-only">(opens in new tab)</span>
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.125rem;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: 1.35rem;
    font-optical-sizing: auto;
    text-decoration: none;
    color: var(--color-text);
    letter-spacing: -0.02em;
    transition: color var(--transition);
    line-height: 1;
  }

  .nav__logo:hover {
    color: var(--color-accent);
  }

  .nav__list {
    display: none;
    list-style: none;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav__list a {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .nav__list a:hover,
  .nav__list a[aria-current="page"] {
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .nav__list {
      display: flex;
    }
  }
</style>
