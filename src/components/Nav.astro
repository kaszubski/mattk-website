---
import type { Translations } from "@/i18n";

interface Props {
  t: Translations;
  activePage?: "home" | "about";
}

const { t, activePage = "home" } = Astro.props;
---

<header class="site-header">
  <nav class="container container--wide nav" aria-label="Primary navigation">
    <a class="nav__logo" href="/" aria-label={`${t.siteTitle} — home`}>
      MK
    </a>

    <ul class="nav__list" role="list">
      <li>
        <a
          href="/#writing"
          class:list={[{ active: activePage === "home" }]}
          aria-current={activePage === "home" ? "page" : undefined}
        >{t.nav.writing}</a>
      </li>
      <li>
        <a
          href="/about/"
          class:list={[{ active: activePage === "about" }]}
          aria-current={activePage === "about" ? "page" : undefined}
        >{t.nav.about}</a>
      </li>
      <li>
        <a
          href="https://www.meetup.com/engineering-leadership-warsaw/"
          rel="noopener noreferrer"
          target="_blank"
          class="nav__external"
        >
          {t.nav.elw}
          <span class="sr-only">(opens in new tab)</span>
          <span class="nav__ext-icon" aria-hidden="true">↗</span>
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(7, 8, 10, 0.75);
    backdrop-filter: blur(16px) saturate(1.6);
    -webkit-backdrop-filter: blur(16px) saturate(1.6);
    border-bottom: 1px solid var(--color-border);
  }

  .nav {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav__logo {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.1rem;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .nav__logo:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .nav__list {
    display: none;
    list-style: none;
    align-items: center;
    gap: 0.25rem;
  }

  .nav__list a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.02em;
    color: var(--color-text-2);
    text-decoration: none;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition), background var(--transition);
  }

  .nav__list a:hover,
  .nav__list a.active {
    color: var(--color-text);
    background: rgba(255, 255, 255, 0.06);
    opacity: 1;
  }

  .nav__external {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .nav__ext-icon {
    font-size: 0.65rem;
    opacity: 0.5;
  }

  @media (min-width: 768px) {
    .nav__list { display: flex; }
  }
</style>
