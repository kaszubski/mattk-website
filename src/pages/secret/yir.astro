---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
---

<BaseLayout
  t={t}
  title="Year in Review"
  description="A little something for friends."
  noindex
>
  <Nav t={t} />

  <main id="main-content">
    <div class="yir-page">
      <div class="container container--wide">

        <header class="yir-page__header">
          <p class="mono yir-page__label">Unlisted — private link</p>
          <h1 class="yir-page__title">Year in Review — Award</h1>
          <p class="yir-page__intro">
            Personalised annual recap for Asana users — a 12-slide, reels-like experience
            with themed colour transitions between sections, custom 2D physics, character
            animation, interactive parallax, animated data visuals, and reduced-motion
            fallbacks. Supported the initiative as a year wrap-up, helping coordinate the
            cross-functional team and contributing to coding standards and technical
            review along the way.
          </p>
          <p class="yir-page__note">
            This page is unlisted and shared on a private basis. If you have this URL,
            it was sent to you directly — please don't redistribute it outside that context.
          </p>
        </header>

        <section class="yir-page__video" aria-label="Year in review video">
          <video
            controls
            playsinline
            preload="metadata"
            src="/videos/yir-award.mp4"
          >
            Your browser doesn't support HTML video.
            <a href="/videos/yir-award.mp4">Download the clip</a> instead.
          </video>
        </section>

      </div>
    </div>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .yir-page {
    padding-block: clamp(2.5rem, 5vw, 4rem) clamp(3rem, 6vw, 5rem);
  }

  .yir-page__header {
    margin-bottom: var(--space-xl);
  }

  .yir-page__label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
  }

  .yir-page__title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .yir-page__intro {
    font-size: var(--text-base);
    color: var(--color-text-2);
    max-width: 62ch;
    line-height: 1.7;
  }

  .yir-page__note {
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-faint);
    max-width: 62ch;
    line-height: 1.6;
    font-style: italic;
  }

  .yir-page__video {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-bg-overlay);
    border: 1px solid var(--color-border);
  }

  .yir-page__video video {
    display: block;
    width: 100%;
    height: auto;
  }
</style>
