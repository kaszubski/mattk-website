---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
---

<BaseLayout
  t={t}
  title={t.writing.title}
  description={t.writing.description}
>
  <Nav t={t} activePage="writing" />

  <main id="main-content">
    <article class="writing-page" aria-labelledby="writing-heading">
      <div class="container">

        <header class="writing-page__header">
          <p class="mono writing-page__label">Writing</p>
          <h1 id="writing-heading" class="writing-page__title">Things I've written</h1>
          <p class="writing-page__desc">{t.writing.description}</p>
        </header>

        {t.writing.sections.map((section) => (
          <section class="writing-section reveal" aria-labelledby={`section-${section.id}`}>
            <h2 id={`section-${section.id}`} class="writing-section__heading mono">
              {section.label}
            </h2>

            <ul class="posts" role="list">
              {section.posts.map((post) => (
                <li class="post">
                  <a class="post__inner" href={`/writing/${post.slug}/`}>
                    <span class="post__date mono">{post.date}</span>
                    <div class="post__body">
                      <span class="post__title">{post.title}</span>
                      <span class="post__desc">{post.description}</span>
                    </div>
                    <span class="post__arrow" aria-hidden="true">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}

        <footer class="writing-page__footer reveal">
          <a
            href={t.writing.allPostsUrl}
            class="writing-page__medium-link mono"
            rel="noopener noreferrer"
            target="_blank"
          >
            {t.writing.allPostsOnMedium} <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
          </a>
        </footer>

      </div>
    </article>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .writing-page {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* Header */
  .writing-page__header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .writing-page__label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
  }

  .writing-page__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .writing-page__desc {
    font-size: var(--text-sm);
    color: var(--color-text);
    max-width: 52ch;
    line-height: 1.7;
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  /* Sections */
  .writing-section {
    margin-bottom: var(--space-xl);
  }

  .writing-section__heading {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    font-family: var(--font-mono);
    font-weight: 400;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  /* Posts */
  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .post {
    border-bottom: 1px solid var(--color-border);
  }

  .post__inner {
    display: grid;
    grid-template-columns: minmax(4.25rem, auto) 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: 1.1rem 0.75rem;
    margin-inline: -0.75rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-md);
    cursor: pointer;
  }

  .post__inner:hover {
    background: var(--color-bg-elevated);
    opacity: 1;
  }

  .post__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .post__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    transition: color var(--transition);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post__inner:hover .post__title {
    color: var(--color-accent);
  }

  .post__desc {
    font-size: var(--text-xs);
    color: var(--color-text);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post__date {
    color: var(--color-text-faint);
    font-size: 0.68rem;
    line-height: 1.3;
    flex-shrink: 0;
    align-self: start;
    padding-top: 0.15rem;
  }

  .post__arrow {
    color: var(--color-text-faint);
    font-size: var(--text-sm);
    flex-shrink: 0;
    transition: color var(--transition), translate var(--transition);
  }

  .post__inner:hover .post__arrow {
    color: var(--color-accent);
    translate: 3px 0;
  }

  @media (min-width: 768px) {
    .post__inner {
      grid-template-columns: 5.5rem 1fr 1.5rem;
    }

    .post__date {
      align-self: center;
      padding-top: 0;
    }

    .post__title {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
    }
  }

  /* Footer */
  .writing-page__footer {
    padding-top: var(--space-lg);
  }

  .writing-page__medium-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-2);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .writing-page__medium-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* Page load animation */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.75rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .writing-page__header { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) both; }
  }
</style>
