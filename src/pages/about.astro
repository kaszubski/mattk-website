---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
import { writingSlugFromEntryId } from "@/lib/post-slug";

const allPosts = await getCollection("writing");
const bySlug = Object.fromEntries(
  allPosts.map((post) => [writingSlugFromEntryId(post.id), post]),
);

const featuredEssays = t.about.featuredWritingSlugs.flatMap((slug) => {
  const post = bySlug[slug];
  return post ? [{ slug, title: post.data.title }] : [];
});

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Matt Kaszubski",
  jobTitle: "Engineering Leader",
  worksFor: { "@type": "Organization", name: "Asana" },
  url: new URL("/about/", Astro.site ?? Astro.url).href,
  description: t.about.shortBio,
  sameAs: [
    "https://www.linkedin.com/in/kaszubski/",
    "https://github.com/kaszubski",
    "https://medium.com/@matt.kaszubski",
    "https://x.com/kaszubski_",
  ],
};
---

<BaseLayout
  t={t}
  title={t.about.title}
  description={t.about.shortBio}
  jsonLd={aboutJsonLd}
>
  <Nav t={t} activePage="about" />

  <main id="main-content">
    <article class="about" aria-labelledby="about-heading">
      <div class="container">
        <header class="about__header">
          <p class="mono about__page-label">{t.about.pageLabel}</p>
          <h1 id="about-heading" class="about__title">{t.about.headline}</h1>
          <p class="mono about__tagline">{t.about.tagline}</p>
        </header>

        <div class="about__narrative reveal">
          {t.about.narrative.map((para) => <p>{para}</p>)}
        </div>

        <section class="about__writing reveal" aria-labelledby="essays-heading">
          <h2 id="essays-heading" class="mono about__writing-label">{t.about.featuredWritingSectionLabel}</h2>
          <p class="about__writing-intro">{t.about.featuredWritingIntro}</p>
          <ul class="about__essay-list" role="list">
            {featuredEssays.map((post) => (
              <li>
                <a class="about__essay-link" href={`/writing/${post.slug}/`}>
                  <span class="about__essay-title">{post.title}</span>
                  <span class="about__essay-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
          <a href="/writing/" class="mono about__all-writing">{t.about.allWritingLabel}<span aria-hidden="true"> →</span></a>
        </section>

        <p class="about__cta reveal">
          {t.about.closingLead}{" "}
          <a
            href={t.about.closingCtaHref}
            class="about__cta-link"
            rel="noopener noreferrer"
            target="_blank"
          >
            {t.about.closingCtaLabel}<span aria-hidden="true"> ↗</span>
            <span class="sr-only"> (opens in new tab)</span>
          </a>
        </p>

        <aside class="about__bio reveal" aria-labelledby="bio-label">
          <h2 id="bio-label" class="mono about__bio-label">{t.about.shortBioLabel}</h2>
          <p class="about__bio-text">{t.about.shortBio}</p>
        </aside>

        <aside class="about__glossary reveal" aria-labelledby="glossary-label">
          <h2 id="glossary-label" class="mono about__glossary-label">Glossary</h2>
          <dl class="about__glossary-list">
            <div class="about__glossary-entry">
              <dt><abbr title="Individual Contributor">IC</abbr></dt>
              <dd>Individual Contributor — an engineer who ships directly, not managing others</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Engineering Manager">EM</abbr></dt>
              <dd>Engineering Manager</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Key Performance Indicator">KPI</abbr></dt>
              <dd>Key Performance Indicator</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Situational Leadership II">SLII</abbr></dt>
              <dd>Situational Leadership II — the Blanchard adaptive leadership model</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="DevOps Research and Assessment">DORA</abbr></dt>
              <dd>DevOps Research and Assessment — four key software delivery metrics</dd>
            </div>
          </dl>
        </aside>

        <nav class="about__connect reveal" aria-label="Social links">
          <p class="mono about__connect-label">{t.about.connectLabel}</p>
          <ul class="about__links" role="list">
            <li>
              <a href="https://www.linkedin.com/in/kaszubski/" rel="noopener noreferrer" target="_blank">
                LinkedIn <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://medium.com/@matt.kaszubski" rel="noopener noreferrer" target="_blank">
                Medium <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://github.com/kaszubski" rel="noopener noreferrer" target="_blank">
                GitHub <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://x.com/kaszubski_" rel="noopener noreferrer" target="_blank">
                X <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </article>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .about {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* Header */
  .about__header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .about__page-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
  }

  .about__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .about__tagline {
    color: var(--color-text-2);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 0.65rem;
    line-height: 1.5;
    max-width: 52ch;
  }

  /* Narrative */
  .about__narrative {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .about__narrative p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  /* Featured writing */
  .about__writing {
    max-width: 58ch;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }

  .about__writing-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .about__writing-intro {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--space-md);
    max-width: 52ch;
  }

  .about__essay-list {
    list-style: none;
    margin: 0 0 var(--space-md);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 1px solid var(--color-border);
  }

  .about__essay-list li {
    border-bottom: 1px solid var(--color-border);
  }

  .about__essay-link {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-md);
    padding: 0.95rem 0.35rem;
    margin-inline: -0.35rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-md);
  }

  .about__essay-link:hover {
    background: var(--color-bg-elevated);
    opacity: 1;
  }

  .about__essay-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.25;
    transition: color var(--transition);
  }

  .about__essay-link:hover .about__essay-title {
    color: var(--color-accent);
  }

  .about__essay-arrow {
    color: var(--color-text-faint);
    font-size: var(--text-sm);
    flex-shrink: 0;
    transition: color var(--transition), translate var(--transition);
  }

  .about__essay-link:hover .about__essay-arrow {
    color: var(--color-accent);
    translate: 3px 0;
  }

  .about__all-writing {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-faint);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .about__all-writing:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* CTA */
  .about__cta {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  .about__cta-link {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  .about__cta-link:hover {
    opacity: 1;
  }

  /* Short bio */
  .about__bio {
    max-width: 58ch;
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-left: 2px solid var(--color-accent);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-xl);
  }

  .about__bio-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-sm);
  }

  .about__bio-text {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  /* Glossary */
  .about__glossary {
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .about__glossary-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .about__glossary-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about__glossary-entry {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-md);
    align-items: baseline;
  }

  .about__glossary-entry dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .about__glossary-entry dt abbr {
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    cursor: help;
  }

  .about__glossary-entry dd {
    font-size: var(--text-xs);
    color: var(--color-text-2);
    line-height: 1.5;
  }

  /* Connect */
  .about__connect {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__connect-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
  }

  .about__links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .about__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    min-height: 44px;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .about__links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.75rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .about__header { animation: fade-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
  }
</style>
