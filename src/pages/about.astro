---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
---

<BaseLayout
  t={t}
  title={t.about.title}
  description={t.about.shortBio}
>
  <Nav t={t} activePage="about" />

  <main id="main-content">
    <article class="about" aria-labelledby="about-heading">
      <div class="container">

        <!-- Heading -->
        <header class="about__header">
          <h1 id="about-heading" class="about__name">Matt Kaszubski</h1>
        </header>

        <!-- Narrative -->
        <div class="about__narrative reveal">
          {t.about.narrative.map((para) => <p>{para}</p>)}
        </div>

        <!-- Short bio -->
        <aside class="about__bio reveal" aria-labelledby="bio-label">
          <h2 id="bio-label" class="about__bio-label">{t.about.shortBioLabel}</h2>
          <p class="about__bio-text">{t.about.shortBio}</p>
        </aside>

        <!-- Links -->
        <nav class="about__links reveal" aria-label="Social links">
          <span class="about__links-label">{t.about.connectLabel}</span>
          <ul role="list">
            <li>
              <a href="https://www.linkedin.com/in/mateuszkaszubski/" rel="noopener noreferrer" target="_blank">
                LinkedIn
              </a>
            </li>
            <li>
              <a href="https://medium.com/@mateuszkaszubski" rel="noopener noreferrer" target="_blank">
                Medium
              </a>
            </li>
            <li>
              <a href="https://github.com/kaszubski" rel="noopener noreferrer" target="_blank">
                GitHub
              </a>
            </li>
            <li>
              <a href="https://www.meetup.com/engineering-leadership-warsaw/" rel="noopener noreferrer" target="_blank">
                ELW
              </a>
            </li>
          </ul>
        </nav>

      </div>
    </article>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .about {
    padding-block: var(--space-2xl);
  }

  /* Heading */
  .about__header {
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-xl);
  }

  .about__name {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.035em;
    line-height: 1;
    font-optical-sizing: auto;
    font-variation-settings: "opsz" 48;
  }

  /* Narrative prose */
  .about__narrative {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 60ch;
    margin-bottom: var(--space-2xl);
  }

  .about__narrative p {
    font-size: var(--text-base);
    line-height: 1.85;
    color: var(--color-text);
  }

  /* Short bio */
  .about__bio {
    padding: var(--space-lg);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    margin-bottom: var(--space-2xl);
    max-width: 60ch;
  }

  .about__bio-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin-bottom: var(--space-sm);
  }

  .about__bio-text {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    line-height: 1.7;
  }

  /* Links */
  .about__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about__links-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .about__links ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .about__links a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition);
  }

  .about__links a:hover {
    color: var(--color-accent);
  }

  /* Load animation */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes page-in {
      from { opacity: 0; translate: 0 0.5rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .about__header {
      animation: page-in 0.5s ease-out both;
    }

    .about__narrative {
      animation: page-in 0.5s ease-out 0.08s both;
    }
  }
</style>
