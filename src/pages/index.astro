---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";

const nameLines = ["Matt", "Kaszubski"];
---

<BaseLayout t={t}>
  <Nav t={t} activePage="home" />

  <main id="main-content">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="hero" aria-label="Introduction">
      <div class="container">

        <div class="hero__status">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="mono">Lead Creative Technologist · Asana · Warsaw</span>
        </div>

        <h1 class="hero__name" aria-label="Matt Kaszubski">
          {nameLines.map((line, lineIndex) => (
            <span class="hero__name-line" aria-hidden="true">
              {line.split("").map((char, charIndex) => {
                const globalIndex = lineIndex === 0 ? charIndex : nameLines[0].length + 1 + charIndex;
                return (
                  <span
                    class="hero__letter"
                    style={`animation-delay: ${globalIndex * 38}ms`}
                  >{char}</span>
                );
              })}
            </span>
          ))}
        </h1>

        <p class="hero__intro">{t.home.intro}</p>

        <div class="hero__links">
          <a href="/writing/" class="hero__cta">
            <span>Read writing</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href="/about/" class="hero__cta hero__cta--ghost">
            <span>About</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>

      </div>
    </section>

    <!-- ── Writing ───────────────────────────────────────── -->
    <section id="writing" class="writing" aria-labelledby="writing-heading">
      <div class="container">

        <div class="writing__header">
          <h2 id="writing-heading" class="mono writing__label">{t.home.writing.title}</h2>
          <a
            href={t.home.writing.allPostsUrl}
            class="mono writing__all"
            rel="noopener noreferrer"
            target="_blank"
          >
            {t.home.writing.allPosts} ↗
          </a>
        </div>

        <ol class="posts" role="list">
          {
            t.home.writing.posts.map((post, i) => (
              <li class="post reveal">
                <a
                  class="post__inner"
                  href={post.url}
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  <span class="post__num mono">0{i + 1}</span>
                  <div class="post__body">
                    <span class="post__title">{post.title}</span>
                    <span class="post__desc">{post.description}</span>
                  </div>
                  <span class="post__date mono">{post.date}</span>
                  <span class="post__arrow" aria-hidden="true">↗</span>
                </a>
              </li>
            ))
          }
        </ol>

      </div>
    </section>

  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    padding-block: clamp(4rem, 8vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(94,234,212,0.4); }
      50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(94,234,212,0); }
    }
    .status-dot {
      animation: pulse-dot 2.4s ease-in-out infinite;
    }
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.93;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .hero__intro {
    font-size: var(--text-base);
    color: var(--color-text-2);
    line-height: 1.75;
    max-width: 52ch;
    margin-bottom: var(--space-xl);
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent);
    color: var(--color-bg);
    background: var(--color-accent);
    transition: opacity var(--transition), background var(--transition), color var(--transition);
  }

  .hero__cta:hover {
    opacity: 0.85;
  }

  .hero__cta--ghost {
    background: transparent;
    color: var(--color-text-2);
    border-color: var(--color-border-hover);
  }

  .hero__cta--ghost:hover {
    color: var(--color-text);
    border-color: var(--color-text-2);
    opacity: 1;
  }

  /* ── Writing ─────────────────────────────────────────── */
  .writing {
    padding-bottom: var(--space-xl);
  }

  .writing__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-md);
    margin-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-border);
  }

  .writing__label {
    color: var(--color-text-faint);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.65rem;
  }

  .writing__all {
    color: var(--color-text-2);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .writing__all:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* ── Posts ───────────────────────────────────────────── */
  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .post {
    border-bottom: 1px solid var(--color-border);
  }

  .post__inner {
    display: grid;
    grid-template-columns: 2rem 1fr auto auto;
    align-items: center;
    gap: var(--space-md);
    padding: 1.1rem 0.75rem;
    margin-inline: -0.75rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    color: var(--color-text);
    transition: background var(--transition-md);
    cursor: pointer;
  }

  .post__inner:hover {
    background: var(--color-bg-elevated);
    opacity: 1;
  }

  .post__num {
    color: var(--color-text-faint);
    font-size: 0.7rem;
  }

  .post__body {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .post__title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    transition: color var(--transition);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post__inner:hover .post__title {
    color: var(--color-accent);
  }

  .post__desc {
    font-size: var(--text-xs);
    color: var(--color-text-2);
    line-height: 1.5;
    display: none;
  }

  .post__date {
    color: var(--color-text-faint);
    font-size: 0.68rem;
    flex-shrink: 0;
  }

  .post__arrow {
    color: var(--color-text-faint);
    font-size: var(--text-sm);
    flex-shrink: 0;
    transition: color var(--transition), translate var(--transition);
  }

  .post__inner:hover .post__arrow {
    color: var(--color-accent);
    translate: 1px -1px;
  }

  @media (min-width: 768px) {
    .post__inner {
      grid-template-columns: 2.5rem 1fr 4rem 1.5rem;
    }

    .post__desc {
      display: block;
    }

    .post__title {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
    }
  }

  /* ── Name layout — always visible as fallback ────────── */
  .hero__name {
    cursor: crosshair;
  }

  .hero__name-line {
    display: block;
    white-space: nowrap;
  }

  .hero__letter {
    display: inline-block;
    scale: 1; /* explicit — prevents repaint when animation clears its scale:1 */
    color: var(--color-text);
    /* Proximity glow — driven by --glow (0…1) set via JS mousemove */
    color: color-mix(in oklch, var(--color-accent) calc(var(--glow, 0) * 100%), var(--color-text));
    text-shadow:
      0 0 calc(var(--glow, 0) * 28px) rgba(94, 234, 212, calc(var(--glow, 0) * 0.75)),
      0 0 calc(var(--glow, 0) * 60px) rgba(94, 234, 212, calc(var(--glow, 0) * 0.25));
    transition: color 0.25s ease, text-shadow 0.25s ease;
  }

  /* ── Load animations ─────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    /*
     * Each letter materializes from glowing teal blur → crisp white.
     * No background-clip — avoids the WebKit filter/stacking-context bug.
     * The staggered teal→white wave IS the shimmer effect.
     */
    @keyframes materialize {
      0%   { opacity: 0; color: var(--color-accent); filter: blur(14px) brightness(3); scale: 1.2;  }
      45%  { opacity: 1; color: var(--color-accent); filter: blur(3px)  brightness(1.8); scale: 1.03; }
      75%  {             color: var(--color-accent); filter: blur(0)    brightness(1.1); scale: 1;   }
      100% {             color: var(--color-text);   filter: blur(0)    brightness(1);   scale: 1;   }
    }

    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.6rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .hero__letter {
      animation: materialize 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .hero__status { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) both; }
    .hero__intro  { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) 0.9s both; }
    .hero__links  { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) 1.0s both; }
  }
</style>

<script>
  const name = document.querySelector<HTMLElement>('.hero__name');
  if (name) {
    const letters = Array.from(name.querySelectorAll<HTMLElement>('.hero__letter'));

    // animation-fill-mode: both holds the final keyframe color in the cascade,
    // overriding the base CSS color-mix(). Clear it once the animation ends
    // so the custom property can take effect.
    letters.forEach(letter => {
      letter.addEventListener('animationend', () => {
        // Suppress transition before clearing animation — prevents the active
        // transition from firing a single-frame flash on property recalc.
        letter.style.transition = 'none';
        letter.style.animation = 'none';
        // Double rAF: first frame applies the no-transition state,
        // second frame re-enables transitions for the hover effect.
        requestAnimationFrame(() => requestAnimationFrame(() => {
          letter.style.transition = '';
        }));
      }, { once: true });
    });

    if (window.matchMedia('(pointer: fine)').matches) {
      const RADIUS = 140;

      name.addEventListener('mousemove', (e: MouseEvent) => {
        letters.forEach(letter => {
          const rect = letter.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dist = Math.hypot(e.clientX - cx, e.clientY - cy);
          const glow = Math.max(0, 1 - dist / RADIUS);
          letter.style.setProperty('--glow', glow.toFixed(3));
        });
      });

      name.addEventListener('mouseleave', () => {
        letters.forEach(l => l.style.removeProperty('--glow'));
      });
    }
  }
</script>
