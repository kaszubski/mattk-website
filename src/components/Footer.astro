---
import type { Translations } from "@/i18n";

interface Props {
  t: Translations;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container--wide footer">
    <p class="footer__copy mono">&copy; {year} {t.siteTitle} · <a href="/accessibility/">Accessibility</a></p>
    <div class="footer__links">
      <a href="https://www.linkedin.com/in/kaszubski/" rel="noopener noreferrer" target="_blank">LinkedIn<span class="sr-only"> (opens in new tab)</span></a>
      <a href="https://github.com/kaszubski" rel="noopener noreferrer" target="_blank">GitHub<span class="sr-only"> (opens in new tab)</span></a>
      <a href="https://medium.com/@mateuszkaszubski" rel="noopener noreferrer" target="_blank">Medium<span class="sr-only"> (opens in new tab)</span></a>
      <a href="https://x.com/kaszubski_" rel="noopener noreferrer" target="_blank">X<span class="sr-only"> (opens in new tab)</span></a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-lg);
    margin-top: var(--space-2xl);
  }

  .footer {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--space-md);
    align-items: center;
    text-align: center;
  }

  .footer__copy {
    color: var(--color-text-faint);
  }

  .footer__copy a {
    color: var(--color-text-faint);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__copy a:hover {
    color: var(--color-text-2);
  }

  .footer__links {
    display: flex;
    gap: var(--space-lg);
  }

  .footer__links a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color var(--transition);
    display: inline-flex;
    align-items: center;
    min-height: 44px;
  }

  .footer__links a:hover {
    color: var(--color-text);
    opacity: 1;
  }

  @media (min-width: 768px) {
    .footer {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
