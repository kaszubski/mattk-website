---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
---

<BaseLayout
  t={t}
  title="Page not found"
  description="The page you're looking for doesn't exist."
>
  <Nav t={t} />

  <main id="main-content">
    <div class="not-found">
      <div class="container">
        <p class="mono not-found__code">404</p>
        <h1 class="not-found__heading">Page not found</h1>
        <p class="not-found__desc">
          The page you're looking for doesn't exist or may have been moved.
        </p>
        <nav class="not-found__links" aria-label="Recovery options">
          <a href="/" class="not-found__link">← Home</a>
          <a href="/writing/" class="not-found__link">Writing</a>
          <a href="/about/" class="not-found__link">About</a>
        </nav>
      </div>
    </div>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    min-height: calc(100dvh - var(--nav-height) - 10rem);
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .not-found__code {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
  }

  .not-found__heading {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .not-found__desc {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    max-width: 40ch;
    line-height: 1.7;
    margin-bottom: var(--space-xl);
  }

  .not-found__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .not-found__link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .not-found__link:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.75rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .not-found { animation: fade-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
  }
</style>
