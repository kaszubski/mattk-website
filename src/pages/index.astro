---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";

const nameLines = ["Matt", "Kaszubski"];
const experienceCompanies = ["Asana", "Sii", "Mindtree", "Amartus", "IG"] as const;

const homeJsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "Matt Kaszubski",
      url: Astro.site?.href ?? Astro.url.origin,
    },
    {
      "@type": "Person",
      name: "Matt Kaszubski",
      jobTitle: "Engineering Leader",
      worksFor: { "@type": "Organization", name: "Asana" },
      url: Astro.site?.href ?? Astro.url.origin,
      sameAs: [
        "https://www.linkedin.com/in/kaszubski/",
        "https://github.com/kaszubski",
        "https://medium.com/@mateuszkaszubski",
      ],
    },
  ],
};
---

<BaseLayout t={t} jsonLd={homeJsonLd}>
  <Nav t={t} activePage="home" />

  <main id="main-content">

    <!-- ── Hero ──────────────────────────────────────────── -->
    <section class="hero" aria-label="Introduction">
      <div class="container">

        <div class="hero__status">
          <span class="status-dot" aria-hidden="true"></span>
          <span class="mono">Engineering Leader @ Asana · 0→1 Digital Engineering, Warsaw · AI-enabled teams</span>
        </div>

        <h1 class="hero__name" aria-label="Matt Kaszubski">
          {nameLines.map((line, lineIndex) => (
            <span class="hero__name-line" aria-hidden="true">
              {line.split("").map((char, charIndex) => {
                const globalIndex = lineIndex === 0 ? charIndex : nameLines[0].length + 1 + charIndex;
                return (
                  <span
                    class="hero__letter"
                    style={`animation-delay: ${globalIndex * 38}ms`}
                  >{char}</span>
                );
              })}
            </span>
          ))}
        </h1>

        <p class="hero__intro">{t.home.intro}</p>

        <div class="hero__links">
          <a href="/writing/" class="hero__cta">
            <span>Read writing</span>
            <span aria-hidden="true">→</span>
          </a>
          <a href="/about/" class="hero__cta hero__cta--ghost">
            <span>About</span>
            <span aria-hidden="true">→</span>
          </a>
        </div>

      </div>
    </section>

    <!-- ── Worked at ─────────────────────────────────────── -->
    <section class="worked" aria-label="Experience">
      <div class="container">
      <div class="worked__label mono">Experience</div>
      <div
        class="worked__track-wrap"
        data-worked-marquee
        tabindex="0"
        role="region"
        aria-label="Companies — drag horizontally or use the mouse wheel; marquee loops"
      >
        <div class="worked__track-shift">
          <ul class="worked__track" role="list">
            {[0, 1, 2].flatMap((copy) =>
              experienceCompanies.map((name) => (
                <li class="worked__item" aria-hidden={copy > 0 ? true : undefined}>
                  {name}
                </li>
              ))
            )}
          </ul>
        </div>
      </div>
      </div>
    </section>

  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  /* ── Hero ────────────────────────────────────────────── */
  .hero {
    padding-block: clamp(4rem, 8vw, 7rem) clamp(3rem, 6vw, 5rem);
  }

  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: var(--space-lg);
  }

  .status-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(94,234,212,0.4); }
      50%       { opacity: 0.7; box-shadow: 0 0 0 4px rgba(94,234,212,0); }
    }
    .status-dot {
      animation: pulse-dot 2.4s ease-in-out infinite;
    }
  }

  .hero__name {
    font-family: var(--font-display);
    font-size: var(--text-display);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.93;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .hero__intro {
    font-size: var(--text-base);
    color: var(--color-text-2);
    line-height: 1.75;
    max-width: 52ch;
    margin-bottom: var(--space-xl);
  }

  .hero__links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-decoration: none;
    min-height: 44px;
    padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-accent);
    color: var(--color-bg);
    background: var(--color-accent);
    transition: opacity var(--transition), background var(--transition), color var(--transition);
  }

  .hero__cta:hover {
    opacity: 0.85;
  }

  .hero__cta--ghost {
    background: transparent;
    color: var(--color-text-2);
    border-color: var(--color-border-hover);
  }

  .hero__cta--ghost:hover {
    color: var(--color-text);
    border-color: var(--color-text-2);
    opacity: 1;
  }

  /* ── Name layout — always visible as fallback ────────── */
  .hero__name {
    cursor: crosshair;
  }

  .hero__name-line {
    display: block;
    white-space: nowrap;
  }

  .hero__letter {
    display: inline-block;
    scale: 1; /* explicit — prevents repaint when animation clears its scale:1 */
    color: var(--color-text);
    /* Proximity glow — driven by --glow (0…1) set via JS mousemove */
    color: color-mix(in oklch, var(--color-accent) calc(var(--glow, 0) * 100%), var(--color-text));
    text-shadow:
      0 0 calc(var(--glow, 0) * 28px) rgba(94, 234, 212, calc(var(--glow, 0) * 0.75)),
      0 0 calc(var(--glow, 0) * 60px) rgba(94, 234, 212, calc(var(--glow, 0) * 0.25));
    transition: color 0.25s ease, text-shadow 0.25s ease;
  }

  /* ── Worked at ───────────────────────────────────────── */
  .worked {
    padding-block: clamp(2.5rem, 5vw, 4rem);
    border-top: 1px solid var(--color-border);
  }

  .worked__label {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.6rem;
    color: var(--color-text-faint);
    margin-bottom: var(--space-lg);
  }

  .worked__track-wrap {
    --worked-drag: grab;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    cursor: var(--worked-drag);
    margin-inline: calc(var(--space-lg) * -1);
    padding-inline: var(--space-lg);
    touch-action: none;
  }

  .worked__track-wrap.is-dragging {
    --worked-drag: grabbing;
    user-select: none;
  }

  .worked__track-wrap.is-dragging .worked__item {
    pointer-events: none;
  }

  .worked__track-wrap:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .worked__track-shift {
    display: flex;
    width: max-content;
    min-height: 2.75rem;
    padding-block: var(--space-xs);
  }

  .worked__track-shift.is-animating {
    will-change: transform;
  }

  .worked__track {
    display: flex;
    align-items: center;
    gap: clamp(2.5rem, 5vw, 4rem);
    margin: 0;
    list-style: none;
    flex-shrink: 0;
  }

  .worked__item {
    font-family: var(--font-display);
    font-size: clamp(1rem, 0.8rem + 1vw, 1.4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text-faint);
    white-space: nowrap;
    flex-shrink: 0;
    cursor: inherit;
    transition: color 0.25s ease, text-shadow 0.25s ease;
  }

  .worked__item:hover {
    color: color-mix(in oklch, var(--color-accent) 100%, var(--color-text));
    text-shadow:
      0 0 28px rgba(94, 234, 212, 0.75),
      0 0 60px rgba(94, 234, 212, 0.25);
  }

  /* ── Load animations ─────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    /*
     * Each letter materializes from glowing teal blur → crisp white.
     * No background-clip — avoids the WebKit filter/stacking-context bug.
     * The staggered teal→white wave IS the shimmer effect.
     */
    @keyframes materialize {
      0%   { opacity: 0; color: var(--color-accent); filter: blur(14px) brightness(3); scale: 1.2;  }
      45%  { opacity: 1; color: var(--color-accent); filter: blur(3px)  brightness(1.8); scale: 1.03; }
      75%  {             color: var(--color-accent); filter: blur(0)    brightness(1.1); scale: 1;   }
      100% {             color: var(--color-text);   filter: blur(0)    brightness(1);   scale: 1;   }
    }

    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.6rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .hero__letter {
      animation: materialize 0.7s cubic-bezier(0.16, 1, 0.3, 1) both;
    }

    .hero__status { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) both; }
    .hero__intro  { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) 0.9s both; }
    .hero__links  { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) 1.0s both; }
  }
</style>

<script>
  const name = document.querySelector<HTMLElement>('.hero__name');
  if (name) {
    const letters = Array.from(name.querySelectorAll<HTMLElement>('.hero__letter'));

    // animation-fill-mode: both holds the final keyframe color in the cascade,
    // overriding the base CSS color-mix(). Clear it once the animation ends
    // so the custom property can take effect.
    letters.forEach(letter => {
      letter.addEventListener('animationend', () => {
        // Suppress transition before clearing animation — prevents the active
        // transition from firing a single-frame flash on property recalc.
        letter.style.transition = 'none';
        letter.style.animation = 'none';
        // Double rAF: first frame applies the no-transition state,
        // second frame re-enables transitions for the hover effect.
        requestAnimationFrame(() => requestAnimationFrame(() => {
          letter.style.transition = '';
        }));
      }, { once: true });
    });

    if (window.matchMedia('(pointer: fine)').matches) {
      const RADIUS = 140;

      name.addEventListener('mousemove', (e: MouseEvent) => {
        letters.forEach(letter => {
          const rect = letter.getBoundingClientRect();
          const cx = rect.left + rect.width / 2;
          const cy = rect.top + rect.height / 2;
          const dist = Math.hypot(e.clientX - cx, e.clientY - cy);
          const glow = Math.max(0, 1 - dist / RADIUS);
          letter.style.setProperty('--glow', glow.toFixed(3));
        });
      });

      name.addEventListener('mouseleave', () => {
        letters.forEach(l => l.style.removeProperty('--glow'));
      });
    }
  }

  const workedWrap = document.querySelector<HTMLElement>('[data-worked-marquee]');
  const workedShift = document.querySelector<HTMLElement>('.worked__track-shift');
  if (workedWrap && workedShift) {
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const AUTO_PX_PER_SEC = 40;

    let setWidth = 0;
    let x = 0;
    let lastT = performance.now();
    let dragPointerId: number | null = null;
    let lastClientX = 0;
    let dragging = false;

    const normalize = (px: number, w: number) => {
      if (w <= 1) return px;
      let out = px;
      while (out > 0) out -= w;
      while (out <= -w) out += w;
      return out;
    };

    const measure = () => {
      const total = workedShift.scrollWidth;
      setWidth = total > 0 ? total / 3 : 0;
    };

    const apply = () => {
      workedShift.style.transform = `translate3d(${x}px, 0, 0)`;
    };

    const remeasureAndClamp = () => {
      measure();
      if (setWidth > 0) x = normalize(x, setWidth);
      apply();
    };

    const tick = (now: number) => {
      const dt = Math.min((now - lastT) / 1000, 0.05);
      lastT = now;
      if (!dragging && !reduceMotion && setWidth > 0) {
        x -= AUTO_PX_PER_SEC * dt;
        x = normalize(x, setWidth);
      }
      apply();
      if (visible) rafId = requestAnimationFrame(tick);
    };

    let visible = false;
    let rafId: number | null = null;

    const startLoop = () => {
      if (rafId !== null) return;
      visible = true;
      workedShift.classList.add('is-animating');
      lastT = performance.now();
      rafId = requestAnimationFrame(tick);
    };

    const stopLoop = () => {
      visible = false;
      if (rafId !== null) { cancelAnimationFrame(rafId); rafId = null; }
      workedShift.classList.remove('is-animating');
    };

    const observer = new IntersectionObserver(
      ([entry]) => { entry.isIntersecting ? startLoop() : stopLoop(); },
      { threshold: 0 },
    );

    measure();
    apply();
    observer.observe(workedWrap);
    new ResizeObserver(remeasureAndClamp).observe(workedShift);

    workedWrap.addEventListener('pointerdown', (e: PointerEvent) => {
      if (e.button !== 0) return;
      dragging = true;
      dragPointerId = e.pointerId;
      lastClientX = e.clientX;
      workedWrap.classList.add('is-dragging');
      try {
        workedWrap.setPointerCapture(e.pointerId);
      } catch {
        /* noop */
      }
    });

    workedWrap.addEventListener('pointermove', (e: PointerEvent) => {
      if (dragPointerId !== e.pointerId) return;
      const dx = e.clientX - lastClientX;
      lastClientX = e.clientX;
      x += dx;
      x = normalize(x, setWidth);
      apply();
    });

    const endWorkedDrag = (e: PointerEvent) => {
      if (dragPointerId !== e.pointerId) return;
      try {
        workedWrap.releasePointerCapture(e.pointerId);
      } catch {
        /* noop */
      }
      dragPointerId = null;
      dragging = false;
      workedWrap.classList.remove('is-dragging');
    };

    workedWrap.addEventListener('pointerup', endWorkedDrag);
    workedWrap.addEventListener('pointercancel', endWorkedDrag);

    workedWrap.addEventListener(
      'wheel',
      (e: WheelEvent) => {
        if (setWidth <= 0) return;
        const absX = Math.abs(e.deltaX);
        const absY = Math.abs(e.deltaY);
        if (absX > absY) {
          e.preventDefault();
          x -= e.deltaX;
        } else if (absY > 0 && absX === 0) {
          return;
        }
        x = normalize(x, setWidth);
        apply();
      },
      { passive: false },
    );

    const KEYBOARD_STEP = 120;
    workedWrap.addEventListener('keydown', (e: KeyboardEvent) => {
      if (setWidth <= 0) return;
      if (e.key === 'ArrowLeft')  { e.preventDefault(); x += KEYBOARD_STEP; }
      else if (e.key === 'ArrowRight') { e.preventDefault(); x -= KEYBOARD_STEP; }
      else return;
      x = normalize(x, setWidth);
      apply();
    });
  }
</script>
