---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";
import { writingSlugFromEntryId } from "@/lib/post-slug";
import type { AstroComponentFactory } from "astro/runtime/server/index.js";

export async function getStaticPaths() {
  const posts = await getCollection("writing");
  return posts.map((post) => ({
    params: { slug: writingSlugFromEntryId(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = writingSlugFromEntryId(post.id);

let Content: AstroComponentFactory | undefined;
let headings: { depth: number; slug: string; text: string }[] = [];
try {
  ({ Content, headings } = await render(post));
} catch (err) {
  console.error(`[writing/${slug}] Failed to render content:`, err);
  return Astro.redirect("/404/");
}

const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
const hasToc = tocHeadings.length > 1;

const mediumUrl = post.data.mediumUrl;

const formattedDate = post.data.date.toLocaleDateString("en-US", {
  month: "short",
  year: "numeric",
});

const articleUrl = new URL(`/writing/${slug}/`, Astro.site ?? Astro.url).href;
const linkedInShareUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(articleUrl)}`;
const xShareUrl = `https://twitter.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(post.data.title)}`;

const siteUrl = (Astro.site ?? Astro.url).origin;
const ogImage = new URL("/og-image.png", Astro.site ?? Astro.url).href;

const articleJsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  image: ogImage,
  author: {
    "@type": "Person",
    name: "Matt Kaszubski",
    url: new URL("/about/", Astro.site ?? Astro.url).href,
  },
  publisher: {
    "@type": "Person",
    name: "Matt Kaszubski",
  },
  url: new URL(`/writing/${slug}/`, Astro.site ?? Astro.url).href,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Writing", item: `${siteUrl}/writing/` },
    { "@type": "ListItem", position: 3, name: post.data.title, item: articleUrl },
  ],
};
---

<BaseLayout
  t={t}
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedTime={post.data.date.toISOString()}
  jsonLd={articleJsonLd}
>
  <Nav t={t} activePage="writing" />

  <main id="main-content">
    <article class="article" aria-labelledby="article-heading">
      <div class={`container ${hasToc ? "container--wide" : ""}`}>
        <div class={`article__layout ${hasToc ? "article__layout--has-toc" : ""}`}>

          <!-- ── Main content column ───────────────────────── -->
          <div class="article__main">
            <header class="article__header">
              <nav class="article__breadcrumb" aria-label="Breadcrumb">
                <ol class="article__breadcrumb-list" role="list">
                  <li class="article__breadcrumb-item">
                    <a href="/" class="article__breadcrumb-link mono">Home</a>
                  </li>
                  <li class="article__breadcrumb-item">
                    <a href="/writing/" class="article__breadcrumb-link mono">Writing</a>
                  </li>
                  <li class="article__breadcrumb-item" aria-current="page">
                    <span class="article__breadcrumb-current mono">Article</span>
                  </li>
                </ol>
              </nav>
              <p class="mono article__category">{post.data.category}</p>
              <h1 id="article-heading" class="article__title">{post.data.title}</h1>
              <div class="article__meta">
                <time class="mono article__date" datetime={post.data.date.toISOString().split("T")[0]}>{formattedDate}</time>
              </div>
            </header>

            <div class="article__body prose">
              {Content && <Content />}
            </div>

            <p class="article__signature">— Matt Kaszubski</p>

            <div class="article__share">
              <p class="article__share-label mono">Share this article</p>
              <div class="article__share-links">
                <a
                  href={linkedInShareUrl}
                  class="article__share-btn"
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  LinkedIn <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
                </a>
                <a
                  href={xShareUrl}
                  class="article__share-btn"
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  X <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
                </a>
              </div>
            </div>

            <footer class="article__footer">
              <a
                href={mediumUrl}
                class="article__medium-cta"
                rel="noopener noreferrer"
                target="_blank"
              >
                <span>Originally published on Medium</span>
                <span class="article__medium-cta-arrow" aria-hidden="true">↗</span>
                <span class="sr-only"> (opens in new tab)</span>
              </a>
              <a href="/writing/" class="article__back-footer mono"><span aria-hidden="true">← </span>Back to writing</a>
            </footer>
          </div>

          <!-- ── TOC sidebar ───────────────────────────────── -->
          {hasToc && (
            <aside class="article__toc-wrap" aria-label="Table of contents">
              <nav class="toc">
                <p class="toc__label mono">Article outline</p>
                <ol class="toc__list" role="list">
                  {tocHeadings.map((h) => (
                    <li class={`toc__item toc__item--h${h.depth}`}>
                      <a
                        href={`#${h.slug}`}
                        class="toc__link"
                        data-heading={h.slug}
                      >
                        {h.text}
                      </a>
                    </li>
                  ))}
                </ol>
              </nav>
            </aside>
          )}

        </div>
      </div>
    </article>
  </main>

  <Footer t={t} />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

<style>
  .article {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* ── Two-column layout ──────────────────────────────────── */
  @media (min-width: 1100px) {
    .article__layout--has-toc {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 200px;
      gap: var(--space-lg);
      align-items: start;
    }
  }

  /* ── Header ─────────────────────────────────────────────── */
  .article__header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  /* ── Breadcrumb ──────────────────────────────────────────── */
  .article__breadcrumb {
    margin-bottom: var(--space-lg);
  }

  .article__breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .article__breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .article__breadcrumb-item:not(:last-child)::after {
    content: "/";
    color: var(--color-text-faint);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    opacity: 0.5;
  }

  .article__breadcrumb-link {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-faint);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .article__breadcrumb-link:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .article__breadcrumb-current {
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    color: var(--color-text-2);
  }

  .article__category {
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
  }

  .article__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .article__desc {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: var(--space-lg);
    text-align: justify;
    hyphens: auto;
  }

  .article__meta {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-top: var(--space-sm);
  }

  .article__date {
    color: var(--color-text-faint);
    font-size: 0.65rem;
  }

  /* ── Body / prose ────────────────────────────────────────── */
  .prose {
    color: var(--color-text);
    line-height: 1.8;
    font-size: var(--text-base);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-top: var(--space-lg);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-md);
    color: var(--color-text);
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .prose :global(em) {
    color: var(--color-text);
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .prose :global(li) {
    color: var(--color-text-2);
    line-height: 1.7;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    padding-left: var(--space-md);
    margin-block: var(--space-lg);
    color: var(--color-text-2);
    font-style: italic;
  }

  .prose :global(blockquote p) {
    margin-bottom: 0;
  }

  .prose :global(pre) {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md);
    overflow-x: auto;
    margin-block: var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--color-accent);
    background: var(--color-bg-elevated);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
  }

  .prose :global(pre code) {
    color: var(--color-text);
    background: none;
    padding: 0;
    font-size: inherit;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-xl);
  }

  .prose :global(.article-image) {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
    border-radius: var(--radius-md);
    margin-block: var(--space-xl);
    border: 1px solid var(--color-border);
    box-shadow: 0 4px 32px color-mix(in srgb, var(--color-accent) 8%, transparent),
                0 1px 8px color-mix(in srgb, black 20%, transparent);
  }

  .prose :global(.article-image-caption) {
    text-align: center;
    text-align-last: center;
    text-wrap: balance;
    hyphens: none;
    margin-top: calc(-1 * (var(--space-xl) - var(--space-sm)));
    margin-bottom: var(--space-xl);
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.02em;
  }

  .prose :global(.article-image-caption a) {
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  /* ── Signature ───────────────────────────────────────────── */
  .article__signature {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-2);
    margin-top: var(--space-lg);
    text-align: right;
  }

  /* ── Article footer ──────────────────────────────────────── */
  .article__footer {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .article__medium-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.6rem 1rem;
    font-size: var(--text-sm);
    color: var(--color-text-2);
    text-decoration: none;
    transition: border-color var(--transition), color var(--transition);
  }

  .article__medium-cta:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    opacity: 1;
  }

  .article__medium-cta-arrow {
    transition: translate var(--transition);
  }

  .article__medium-cta:hover .article__medium-cta-arrow {
    translate: 1px -1px;
  }

  .article__back-footer {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    color: var(--color-text-faint);
    text-decoration: none;
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    transition: color var(--transition);
  }

  .article__back-footer:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  /* ── TOC sidebar ─────────────────────────────────────────── */
  .article__toc-wrap {
    display: none;
  }

  @media (min-width: 1100px) {
    .article__toc-wrap {
      display: block;
      position: sticky;
      top: calc(var(--nav-height) + var(--space-lg));
      max-height: calc(100dvh - var(--nav-height) - var(--space-2xl));
      overflow-y: auto;
      /* Hide scrollbar but keep scrollability */
      scrollbar-width: none;
    }
    .article__toc-wrap::-webkit-scrollbar { display: none; }
  }

  .toc__label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.6rem;
    margin-bottom: var(--space-md);
    display: block;
  }

  .toc__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .toc__item--h3 {
    padding-left: 0.75rem;
  }

  .toc__link {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    line-height: 1.45;
    color: var(--color-text-faint);
    text-decoration: none;
    padding: 0.25rem 0.5rem;
    border-left: 1px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .toc__link:hover {
    color: var(--color-text-2);
    opacity: 1;
  }

  .toc__link.is-active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    background: var(--color-accent-glow);
  }

  /* ── Share ───────────────────────────────────────────────── */
  .article__share {
    margin-top: var(--space-lg);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    flex-wrap: wrap;
  }

  .article__share-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.6rem;
    flex-shrink: 0;
  }

  .article__share-links {
    display: flex;
    gap: var(--space-sm);
  }

  .article__share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    min-height: 44px;
    padding: 0.4rem 0.9rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .article__share-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    opacity: 1;
  }

  /* ── Entry animation ─────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.75rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .article__header { animation: fade-in 0.5s cubic-bezier(0.16,1,0.3,1) both; }
    .article__body   { animation: fade-in 0.5s 0.1s cubic-bezier(0.16,1,0.3,1) both; }
  }
</style>

<script>
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>(".toc__link[data-heading]");
  if (tocLinks.length) {
    const headingEls = Array.from(
      document.querySelectorAll<HTMLElement>(".article__body h2[id], .article__body h3[id]")
    );

    let activeId = "";

    function setActive(id: string) {
      if (id === activeId) return;
      activeId = id;
      tocLinks.forEach((link) => {
        link.classList.toggle("is-active", link.dataset.heading === id);
      });
    }

    function updateActive() {
      // Walk headings bottom-up; first one whose top is above 30% viewport height wins
      const threshold = window.innerHeight * 0.3;
      let current = headingEls[0]?.id ?? "";
      for (const el of headingEls) {
        if (el.getBoundingClientRect().top < threshold) {
          current = el.id;
        }
      }
      setActive(current);
    }

    // Initialise on load, then track scroll
    updateActive();
    window.addEventListener("scroll", updateActive, { passive: true });
  }
</script>
