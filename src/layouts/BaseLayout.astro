---
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import type { Translations } from "@/i18n";
import "@/styles/global.css";

interface Props {
  t: Translations;
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogType?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
  ogImage?: string;
  noindex?: boolean;
}

const { t, title, description, canonicalUrl, ogType = "website", publishedTime, jsonLd, ogImage: ogImageProp, noindex = false } = Astro.props;

const pageTitle = title ? `${title} — ${t.siteTitle}` : t.siteTitle;
const pageDescription = description ?? t.siteDescription;
const canon = canonicalUrl ?? Astro.url.href;
const ogImage = ogImageProp ?? new URL("/og-image.png", Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canon} />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Matt Kaszubski" />
    <meta name="theme-color" content="#07080A" />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta property="og:url" content={canon} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={t.siteTitle} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@kaszubski_" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preload" href="/fonts/syne-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="alternate" type="application/rss+xml" title={t.siteTitle} href="/rss.xml" />
    <script is:inline>
      function applyTheme(){
        var t;try{t=localStorage.getItem('theme')}catch(e){}
        var light=t?t==='light':window.matchMedia('(prefers-color-scheme: light)').matches;
        if(light){document.documentElement.setAttribute('data-theme','light');document.querySelector('meta[name="theme-color"]').content='#F8F9FA'}
        else{document.documentElement.removeAttribute('data-theme');document.querySelector('meta[name="theme-color"]').content='#07080A'}
      }
      function syncToggleBtn(){
        var btn=document.querySelector('[data-theme-toggle]');
        if(!btn)return;
        var isLight=document.documentElement.getAttribute('data-theme')==='light';
        btn.setAttribute('aria-pressed',isLight?'true':'false');
        btn.setAttribute('aria-label',isLight?'Switch to dark theme':'Switch to light theme');
      }
      function applyIntroSeen(){
        try{if(sessionStorage.getItem('intro-seen')){document.documentElement.setAttribute('data-intro-seen','')}}catch(e){}
      }
      function bindSkeletonMedia(root){
        root=root||document;
        root.querySelectorAll('.skeleton-media').forEach(function(wrap){
          if(wrap.dataset.skeletonInit)return;
          wrap.dataset.skeletonInit='1';
          var img=wrap.querySelector('img');
          if(!img){wrap.classList.add('is-loaded');return;}
          function done(){wrap.classList.add('is-loaded');}
          if(img.complete&&img.naturalWidth>0)done();
          else{
            img.addEventListener('load',done,{once:true});
            img.addEventListener('error',done,{once:true});
          }
        });
      }
      function enhanceProseArticleImages(root){
        root=root||document;
        var prose=root.querySelector('.article__body.prose');
        if(!prose)return;
        prose.querySelectorAll('img.article-image').forEach(function(img){
          if(img.closest('.skeleton-media'))return;
          var block=img.parentElement&&img.parentElement.tagName==='PICTURE'?img.parentElement:img;
          var wrap=document.createElement('div');
          wrap.className='skeleton-media skeleton-media--article';
          block.parentNode.insertBefore(wrap,block);
          wrap.appendChild(block);
        });
      }
      function initSkeletonMedia(root){
        root=root||document;
        enhanceProseArticleImages(root);
        bindSkeletonMedia(root);
      }
      applyTheme();
      syncToggleBtn();
      applyIntroSeen();
      document.addEventListener('DOMContentLoaded',function(){initSkeletonMedia(document);});
      document.addEventListener('astro:after-swap',function(){
        applyTheme();
        syncToggleBtn();
        applyIntroSeen();
        initSkeletonMedia(document);
        var main=document.getElementById('main-content');
        if(main){main.setAttribute('tabindex','-1');main.focus({preventScroll:true});}
      });
    </script>
    <ClientRouter />
  </head>
  <body>
    <noscript>
      <style is:global>
        .skeleton-media img {
          opacity: 1 !important;
        }
        .skeleton-media::after {
          display: none !important;
        }
      </style>
    </noscript>
    <a class="skip-nav" href="#main-content">{t.nav.skipToContent}</a>
    <div class="bg-glow" aria-hidden="true"></div>
    <slot />
    <SpeedInsights />
    <Analytics />
  </body>
</html>
