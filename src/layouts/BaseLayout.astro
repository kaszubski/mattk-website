  /* ─── Tokens ─────────────────────────────────────────── */
  :root {
    color-scheme: dark;
    --color-bg:           #07080A;
    --color-bg-elevated:  #0D0F14;
    --color-bg-overlay:   #13151C;

    --color-text:         #EEEEF2;
    --color-text-2:       #B0B0C6;   /* ≈9.4:1 on --color-bg — passes AAA */
    --color-text-faint:   #9898AE;   /* ≈7.1:1 on --color-bg — passes AAA */

    --color-accent:       #5EEAD4;   /* teal — WCAG contrast ~12:1 on bg */
    --color-accent-dim:   rgba(94, 234, 212, 0.18);
    --color-accent-glow:  rgba(94, 234, 212, 0.05);

    --color-border:       rgba(255, 255, 255, 0.16);  /* ≈3:1 on --color-bg — passes 1.4.11 */
    --color-border-hover: rgba(255, 255, 255, 0.28);
    --color-focus:        #5EEAD4;

    --color-dot-grid:     rgba(255, 255, 255, 0.055);
    --color-nav-bg:       rgba(7, 8, 10, 0.75);
    --color-nav-hover-bg: rgba(255, 255, 255, 0.06);

    --font-display: "Syne", sans-serif;
    --font-body:    "Outfit", sans-serif;
    --font-mono:    "DM Mono", monospace;

    --nav-height:   56px;
    --size-content: 680px;
    --size-wide:    960px;

    --space-xs:  0.25rem;
    --space-sm:  0.5rem;
    --space-md:  1rem;
    --space-lg:  2rem;
    --space-xl:  4rem;
    --space-2xl: 7rem;

    --text-xs:      clamp(0.68rem,  0.64rem + 0.2vw,  0.75rem);
    --text-sm:      clamp(0.82rem,  0.78rem + 0.2vw,  0.9rem);
    --text-base:    clamp(0.95rem,  0.9rem  + 0.25vw, 1.05rem);
    --text-lg:      clamp(1.15rem,  1rem    + 0.75vw, 1.4rem);
    --text-xl:      clamp(1.5rem,   1.2rem  + 1.5vw,  2.2rem);
    --text-2xl:     clamp(2.2rem,   1.4rem  + 4vw,    4rem);
    --text-display: clamp(3rem,     1.8rem  + 6vw,    6rem);

    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;

    --transition: 150ms ease;
    --transition-md: 250ms ease;
  }

  /* ─── Light mode ─────────────────────────────────────── */
  [data-theme="light"] {
    color-scheme: light;
    --color-bg:           #F8F9FA;
    --color-bg-elevated:  #FFFFFF;
    --color-bg-overlay:   #F0F1F4;

    --color-text:         #1A1A2E;
    --color-text-2:       #4A4A6A;
    --color-text-faint:   #6A6A8A;

    --color-accent:       #0D7D6D;   /* darker teal for light bg — ~4.8:1 on #F8F9FA */
    --color-accent-dim:   rgba(13, 125, 109, 0.12);
    --color-accent-glow:  rgba(13, 125, 109, 0.05);

    --color-border:       rgba(0, 0, 0, 0.12);
    --color-border-hover: rgba(0, 0, 0, 0.24);
    --color-focus:        #0D7D6D;

    --color-dot-grid:     rgba(0, 0, 0, 0.06);
    --color-nav-bg:       rgba(248, 249, 250, 0.8);
    --color-nav-hover-bg: rgba(0, 0, 0, 0.05);
  }

  /* ─── Reset ──────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; }
  * { margin: 0; padding: 0; }

  html {
    -webkit-text-size-adjust: 100%;
    overflow-y: scroll;
    scrollbar-gutter: stable;
  }

  @media (prefers-reduced-motion: no-preference) {
    html { scroll-behavior: smooth; }
  }

  body {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 400;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    /* Precise dot grid — pure CSS, no assets */
    background-image: radial-gradient(
      circle,
      var(--color-dot-grid) 1px,
      transparent 1px
    );
    background-size: 24px 24px;
    min-height: 100dvh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    padding-top: var(--nav-height);
    cursor: default;
  }

  /* Atmospheric glow at top */
  .bg-glow {
    position: fixed;
    top: 0;
    left: 50%;
    translate: -50% 0;
    width: 80vw;
    height: 40vh;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(94, 234, 212, 0.045) 0%,
      transparent 65%
    );
    pointer-events: none;
    z-index: 0;
  }

  [data-theme="light"] .bg-glow {
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(13, 125, 109, 0.06) 0%,
      transparent 65%
    );
  }

  /* ─── Focus ──────────────────────────────────────────── */
  :focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  /* ─── Base elements ──────────────────────────────────── */
  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition: color var(--transition), opacity var(--transition);
  }
  a:hover { opacity: 0.8; }

  img, video { max-width: 100%; display: block; }

  h1, h2, h3, h4 {
    font-family: var(--font-display);
    line-height: 1.1;
    text-wrap: balance;
    letter-spacing: -0.02em;
  }

  p { text-wrap: pretty; }

  /* ─── Skip nav ───────────────────────────────────────── */
  .skip-nav {
    position: fixed;
    top: -100%;
    left: var(--space-md);
    z-index: 9999;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 500;
    border-radius: var(--radius-sm);
    transition: top var(--transition);
  }
  .skip-nav:focus-visible { top: var(--space-md); }

  /* ─── Layout ─────────────────────────────────────────── */
  .container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--size-content);
    margin-inline: auto;
    padding-inline: var(--space-lg);
  }
  .container--wide { max-width: var(--size-wide); }

  /* ─── Utilities ──────────────────────────────────────── */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }

  .mono {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.02em;
    color: var(--color-text-2);
  }

  /* ─── Animations ─────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    @supports (animation-timeline: view()) {
      @keyframes reveal-up {
        from { opacity: 0; translate: 0 1rem; }
        to   { opacity: 1; translate: 0 0; }
      }
      .reveal {
        animation: reveal-up 0.5s cubic-bezier(0.16, 1, 0.3, 1) both;
        animation-timeline: view();
        animation-range: entry 0% entry 25%;
      }
    }
  }
</style>
