---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import { en as t } from "@/i18n";

const aboutJsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Matt Kaszubski",
  jobTitle: "Engineering Leader",
  worksFor: { "@type": "Organization", name: "Asana" },
  url: new URL("/about/", Astro.site ?? Astro.url).href,
  description: t.about.shortBio,
  sameAs: [
    "https://www.linkedin.com/in/kaszubski/",
    "https://github.com/kaszubski",
    "https://medium.com/@matt.kaszubski",
    "https://x.com/kaszubski_",
  ],
};
---

<BaseLayout
  t={t}
  title={t.about.title}
  description={t.about.shortBio}
  jsonLd={aboutJsonLd}
>
  <Nav t={t} activePage="about" />

  <main id="main-content">
    <div class="reading-progress" aria-hidden="true">
      <div class="reading-progress__bar"></div>
    </div>
    <article class="about" aria-labelledby="about-heading">
      <div class="container">
        <header class="about__header">
          <p class="mono about__page-label">{t.about.pageLabel}</p>
          <h1 id="about-heading" class="about__title" transition:name="page-title">{t.about.headline}</h1>
          <p class="mono about__tagline">{t.about.tagline}</p>
        </header>

        <div class="about__narrative reveal">
          {t.about.narrative.map((para) => <p>{para}</p>)}
        </div>

        <section class="timeline reveal" aria-labelledby="timeline-heading">
          <h2 id="timeline-heading" class="mono timeline__label">{t.about.timelineLabel}</h2>

          <div class="timeline__legend" aria-hidden="true">
            <span class="timeline__legend-item">
              <span class="timeline__legend-dot timeline__legend-dot--em"></span>
              {t.about.timelineEmLabel}
            </span>
            <span class="timeline__legend-item">
              <span class="timeline__legend-dot timeline__legend-dot--tlm"></span>
              {t.about.timelineTlmLabel}
            </span>
            <span class="timeline__legend-item">
              <span class="timeline__legend-dot timeline__legend-dot--ic"></span>
              {t.about.timelineIcLabel}
            </span>
          </div>

          <ol class="timeline__list reveal-stagger" role="list">
            {t.about.timeline.map((entry, i) => (
              <li class={`timeline__entry timeline__entry--${entry.type}`}>
                <div class="timeline__marker" aria-hidden="true">
                  <span class="timeline__dot"></span>
                  {i < t.about.timeline.length - 1 && <span class="timeline__line"></span>}
                </div>
                <div class="timeline__content">
                  <div class="timeline__header">
                    <span class="timeline__company">{entry.company}</span>
                    <span class="mono timeline__period">{entry.period}</span>
                  </div>
                  <p class="timeline__role">{entry.role}</p>
                  <p class="timeline__desc">{entry.description}</p>
                  <span class="mono timeline__type-badge" aria-label={entry.type === 'ic' ? 'Individual Contributor' : entry.type === 'tlm' ? 'Tech Lead / Manager' : 'Engineering Manager'}>
                    {entry.type === 'ic' ? t.about.timelineIcLabel : entry.type === 'tlm' ? t.about.timelineTlmLabel : t.about.timelineEmLabel}
                  </span>
                </div>
              </li>
            ))}
          </ol>
        </section>

        <p class="about__cta reveal">
          {t.about.closingLead}{" "}
          <a
            href={t.about.closingCtaHref}
            class="about__cta-link"
            rel="noopener noreferrer"
            target="_blank"
          >
            {t.about.closingCtaLabel}<span aria-hidden="true"> ↗</span>
            <span class="sr-only"> (opens in new tab)</span>
          </a>
        </p>

        <aside class="about__bio reveal" aria-labelledby="bio-label">
          <h2 id="bio-label" class="mono about__bio-label">{t.about.shortBioLabel}</h2>
          <p class="about__bio-text">{t.about.shortBio}</p>
        </aside>

        <aside class="about__glossary reveal" aria-labelledby="glossary-label">
          <h2 id="glossary-label" class="mono about__glossary-label">Glossary</h2>
          <dl class="about__glossary-list reveal-stagger">
            <div class="about__glossary-entry">
              <dt><abbr title="Individual Contributor">IC</abbr></dt>
              <dd>Individual Contributor — an engineer who ships directly, not managing others</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Engineering Manager">EM</abbr></dt>
              <dd>Engineering Manager</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Technical Lead Manager">TLM</abbr></dt>
              <dd>Technical Lead Manager — leads people and still ships code</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Key Performance Indicator">KPI</abbr></dt>
              <dd>Key Performance Indicator</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="Situational Leadership II">SLII</abbr></dt>
              <dd>Situational Leadership II — the Blanchard adaptive leadership model</dd>
            </div>
            <div class="about__glossary-entry">
              <dt><abbr title="DevOps Research and Assessment">DORA</abbr></dt>
              <dd>DevOps Research and Assessment — four key software delivery metrics</dd>
            </div>
          </dl>
        </aside>

        <div class="about__writing-cta reveal">
          <a href="/writing/" class="about__writing-btn">
            Read my writing <span aria-hidden="true">→</span>
          </a>
        </div>

        <nav class="about__connect reveal" aria-label="Social links">
          <p class="mono about__connect-label">{t.about.connectLabel}</p>
          <ul class="about__links reveal-stagger" role="list">
            <li>
              <a href="https://www.linkedin.com/in/kaszubski/" rel="noopener noreferrer" target="_blank">
                LinkedIn <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://medium.com/@matt.kaszubski" rel="noopener noreferrer" target="_blank">
                Medium <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://github.com/kaszubski" rel="noopener noreferrer" target="_blank">
                GitHub <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            <li>
              <a href="https://x.com/kaszubski_" rel="noopener noreferrer" target="_blank">
                X <span aria-hidden="true">↗</span><span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </article>
  </main>

  <Footer t={t} />
</BaseLayout>

<style>
  .about {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  /* Header */
  .about__header {
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-lg);
  }

  .about__page-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
  }

  .about__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .about__tagline {
    color: var(--color-text-2);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 0.65rem;
    line-height: 1.5;
    max-width: 52ch;
  }

  /* Narrative */
  .about__narrative {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .about__narrative p {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  /* Timeline */
  .timeline {
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .timeline__label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-sm);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .timeline__legend {
    display: flex;
    gap: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .timeline__legend-item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-faint);
  }

  .timeline__legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .timeline__legend-dot--ic { background: var(--color-warm); }
  .timeline__legend-dot--tlm { background: var(--color-accent); }
  .timeline__legend-dot--em { background: var(--color-em); }

  .timeline__list {
    list-style: none;
    position: relative;
  }

  .timeline__entry {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
  }

  .timeline__entry:last-child {
    padding-bottom: 0;
  }

  .timeline__content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: var(--space-sm) var(--space-md);
    margin-inline: calc(-1 * var(--space-md));
    border-radius: var(--radius-md);
    transition: background var(--transition-md);
  }

  .timeline__entry:hover .timeline__content {
    background: var(--color-bg-elevated);
  }

  .timeline__entry:hover .timeline__company {
    color: var(--color-accent);
  }

  .timeline__entry--ic:hover .timeline__company {
    color: var(--color-warm);
  }

  .timeline__entry--em:hover .timeline__company {
    color: var(--color-em);
  }

  .timeline__entry:hover .timeline__dot {
    scale: 1.4;
  }

  .timeline__marker {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.3rem;
  }

  .timeline__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    transition: border-color var(--transition), background var(--transition), scale var(--transition);
  }

  .timeline__entry--ic .timeline__dot {
    border-color: var(--color-warm);
  }

  .timeline__entry--tlm .timeline__dot {
    border-color: var(--color-accent);
  }

  .timeline__entry--em .timeline__dot {
    border-color: var(--color-em);
  }

  .timeline__entry:first-child .timeline__dot {
    background: var(--color-em);
    border-color: var(--color-em);
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-em) 18%, transparent);
  }

  .timeline__line {
    width: 1px;
    flex: 1;
    background: var(--color-border);
    margin-top: var(--space-xs);
  }



  .timeline__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .timeline__company {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--color-text);
    transition: color var(--transition);
  }

  .timeline__period {
    font-size: 0.65rem;
    color: var(--color-text-faint);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }

  .timeline__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    letter-spacing: 0.02em;
  }

  .timeline__desc {
    font-size: var(--text-sm);
    color: var(--color-text-2);
    line-height: 1.6;
    max-width: 48ch;
  }

  .timeline__type-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-sm);
    width: fit-content;
    margin-top: 0.25rem;
  }

  .timeline__entry--ic .timeline__type-badge {
    color: var(--color-warm);
    background: var(--color-warm-dim);
  }

  .timeline__entry--tlm .timeline__type-badge {
    color: var(--color-accent);
    background: var(--color-accent-dim);
  }

  .timeline__entry--em .timeline__type-badge {
    color: var(--color-em);
    background: color-mix(in srgb, var(--color-em) 15%, transparent);
  }

  /* Writing CTA */
  .about__writing-cta {
    margin-bottom: var(--space-xl);
  }

  .about__writing-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    min-height: 44px;
    padding: 0.6rem 1.2rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .about__writing-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    opacity: 1;
  }

  /* CTA */
  .about__cta {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--color-text);
    max-width: 58ch;
    margin-bottom: var(--space-xl);
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  .about__cta-link {
    color: var(--color-accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    white-space: nowrap;
  }

  .about__cta-link:hover {
    opacity: 1;
  }

  /* Short bio */
  .about__bio {
    max-width: 58ch;
    padding: var(--space-lg);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-left: 2px solid var(--color-accent);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-xl);
  }

  .about__bio-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-sm);
  }

  .about__bio-text {
    font-size: var(--text-sm);
    color: var(--color-text);
    line-height: 1.7;
    text-align: justify;
    hyphens: auto;
    hyphenate-limit-chars: 6 3 3;
  }

  /* Glossary */
  .about__glossary {
    max-width: 58ch;
    margin-bottom: var(--space-xl);
  }

  .about__glossary-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .about__glossary-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about__glossary-entry {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    gap: var(--space-md);
    align-items: baseline;
  }

  .about__glossary-entry dt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }

  .about__glossary-entry dt abbr {
    text-decoration: underline dotted;
    text-underline-offset: 3px;
    cursor: help;
  }

  .about__glossary-entry dd {
    font-size: var(--text-xs);
    color: var(--color-text-2);
    line-height: 1.5;
  }

  /* Connect */
  .about__connect {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .about__connect-label {
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.65rem;
  }

  .about__links {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }

  .about__links a {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-2);
    text-decoration: none;
    min-height: 44px;
    padding: 0.5rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: color var(--transition), border-color var(--transition), background var(--transition);
  }

  .about__links a:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-dim);
    background: var(--color-accent-glow);
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    @keyframes fade-in {
      from { opacity: 0; translate: 0 0.75rem; }
      to   { opacity: 1; translate: 0 0; }
    }

    .about__header { animation: fade-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) both; }
  }

  /* Reading progress */
  .reading-progress {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    height: 2px;
    z-index: 99;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress__bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-accent), var(--color-warm));
    border-radius: 0 1px 1px 0;
    transition: width 80ms linear;
    will-change: width;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress__bar { transition: none; }
  }
</style>

<script>
  function initProgressBar() {
    const bar = document.querySelector<HTMLElement>('.reading-progress__bar');
    const content = document.querySelector<HTMLElement>('.about');
    if (!bar || !content) return;

    function updateProgress() {
      const rect = content!.getBoundingClientRect();
      const contentTop = rect.top + window.scrollY;
      const contentHeight = rect.height;
      const scrolled = window.scrollY - contentTop;
      const progress = Math.max(0, Math.min(1, scrolled / (contentHeight - window.innerHeight)));
      bar!.style.width = `${(progress * 100).toFixed(1)}%`;
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  }
  initProgressBar();
  document.addEventListener('astro:after-swap', initProgressBar);
</script>
